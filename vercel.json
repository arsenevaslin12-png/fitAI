{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/config",             "dest": "/api/config.js" },
    { "src": "/api/workout",            "dest": "/api/workout.js" },
    { "src": "/api/bodyscan",           "dest": "/api/bodyscan.js" },
    { "src": "/api/generate-plan",      "dest": "/api/generate-plan.js" },
    { "src": "/api/generate-nutrition",  "dest": "/api/generate-nutrition.js" },
    { "src": "/api/generate-recipe",    "dest": "/api/generate-recipe.js" },
    { "src": "/app.js",                 "dest": "/public/app.js" },
    { "src": "/(.*)",                   "dest": "/public/index.html" }
  ]
}
