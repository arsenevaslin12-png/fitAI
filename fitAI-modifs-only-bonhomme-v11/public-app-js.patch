 // ── Animated stick figure for exercise movements ──────────────────────────────
+function _withUniqueExerciseSvgIds(svg) {
+  const uid = `wt${Math.random().toString(36).slice(2, 9)}`;
+  return String(svg || "")
+    .replace(/id="sf"/g, `id="sf-${uid}"`)
+    .replace(/url\(#sf\)/g, `url(#sf-${uid})`)
+    .replace(/id="hg"/g, `id="hg-${uid}"`)
+    .replace(/url\(#hg\)/g, `url(#hg-${uid})`);
+}
+
+function _exerciseMotionType(name = "") {
+  const nm = String(name || "").toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "");
+  if (/jump|jack|burpee|saut|high.?knees|montee.?genou|mountain|climber/.test(nm)) return 'cardio';
+  if (/squat|fente|lunge|step.?up|mollet|calf/.test(nm)) return 'lower';
+  if (/pompe|push.?up|dip|press|develop|bench|militaire|extension.tricep|curl|elevation|raise|shrug/.test(nm)) return 'upper';
+  if (/souleve|deadlift|terre|sumo|roumain|hip.?thrust|thrust|rowing|tirage|row|pull.?over|oiseau/.test(nm)) return 'hinge';
+  if (/planche|plank|gainage|crunch|abdo|sit.?up|hollow|twist|rotation/.test(nm)) return 'core';
+  if (/etir|stretch|mobilit|yoga|souplesse|respiration|ouverture/.test(nm)) return 'mobility';
+  return 'flow';
+}
+
+function _exerciseMotionBadge(name = "") {
+  const type = _exerciseMotionType(name);
+  return ({ cardio:'Cardio', lower:'Bas du corps', upper:'Haut du corps', hinge:'Chaîne postérieure', core:'Core', mobility:'Mobilité', flow:'Mouvement guidé' })[type] || 'Mouvement guidé';
+}
+
+function _animatedExerciseFigureHtml(name = '', cls = 'wt-demo-figure', label = 'Démo mouvement') {
+  const svg = _withUniqueExerciseSvgIds(_stickFigureSVG(name));
+  const motionType = _exerciseMotionType(name);
+  const badge = _exerciseMotionBadge(name);
+  return `<div class="${cls} motion-${motionType}" data-motion="${motionType}" role="img" aria-label="${escapeAttr(label)}"><div class="wt-motion-stage"><div class="wt-motion-badge">${escapeHtml(badge)}</div><div class="wt-motion-glow wt-motion-glow-a"></div><div class="wt-motion-glow wt-motion-glow-b"></div><div class="wt-motion-svg">${svg}</div></div></div>`;
+}
+
