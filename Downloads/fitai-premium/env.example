# FitAI Pro — environment variables
# Copy into Vercel / local env and fill with real values.

SUPABASE_URL=https://your-project.supabase.co

# Use ONE of the two public keys below
SUPABASE_ANON_KEY=eyJ...legacy_anon_jwt...
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Required only for AI generation. The app still has fallbacks if Gemini is unavailable.
GEMINI_API_KEY=AIza...

# Required for /api/bodyscan because it downloads private storage files server-side.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Optional
BUCKET=user_uploads
ALLOWED_ORIGIN=https://your-app.vercel.app
